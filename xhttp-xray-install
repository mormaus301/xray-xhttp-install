#!/bin/bash
echo -e "\e[1;32mWill be install vless-xhttp-reality and shadowsocks-2022\e[0m"
sleep 3
apt update -y && apt full-upgrade -y
apt install qrencode curl jq -y

# Enable bbr
bbr=$(sysctl -a | grep net.ipv4.tcp_congestion_control)
if [ "$bbr" = "net.ipv4.tcp_congestion_control = bbr" ]; then
echo "bbr is already enabled"
else
echo "net.core.default_qdisc=fq" >> /etc/sysctl.conf
echo "net.ipv4.tcp_congestion_control=bbr" >> /etc/sysctl.conf
sysctl -p
echo "bbr has been enabled"
fi

# Xray-core install
bash -c "$(curl -4 -L https://github.com/XTLS/Xray-install/raw/main/install-release.sh)" @ install
[ -f /usr/local/etc/xray/.keys ] && rm /usr/local/etc/xray/.keys
touch /usr/local/etc/xray/.keys
echo "shortsid: $(openssl rand -hex 8)" >> /usr/local/etc/xray/.keys
echo "uuid: $(xray uuid)" >> /usr/local/etc/xray/.keys
xray x25519 >> /usr/local/etc/xray/.keys

export uuid=$(cat /usr/local/etc/xray/.keys | awk -F': ' '/uuid/ {print $2}')
export privatkey=$(cat /usr/local/etc/xray/.keys | awk -F': ' '/PrivateKey/ {print $2}')
export shortsid=$(cat /usr/local/etc/xray/.keys | awk -F': ' '/shortsid/ {print $2}')

# Generation password for Shadowsocks
ss_password=$(openssl rand -base64 32)

# Create config file
touch /usr/local/etc/xray/config.json
cat << EOF > /usr/local/etc/xray/config.json
{
  "log": {
    "loglevel": "warning"
  },
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "domain": [
          "geosite:category-ads-all",
          "geosite:category-ru"
        ],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "ip": [
          "geoip:cn",
          "geoip:ru",
          "geoip:private"
        ],
      "outboundTag": "block"
      },
      {
        "type": "field",
        "domain": [
          "domain:vk.com",
          "domain:ok.ru",
          "domain:rutube.ru",
          "domain:telega.me",
          "domain:telega.info",
          "domain:ruwiki.ru",
          "domain:max.ru",
          "domain:mail.ru",
          "domain:yandex.ru",
          "domain:ya.ru",
          "domain:yandex.com",
          "domain:yastatic.net",
          "domain:yandex.net",
          "domain:yandexcloud.net",
          "domain:dzen.ru",
          "domain:2ip.io"
          ],
        "outboundTag": "block"
      }
    ]
  },
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "$uuid"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "xhttpSettings": {
          "path": "/",
          "mode": "packet-up"
        },
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "www.dropbox.com:443",
          "serverNames": [
            "www.dropbox.com"
          ],
          "privateKey": "$privatkey",
          "shortIds": [
            "$shortsid"
          ],
          "spiderX": "/",
          "fingerprint": "chrome"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ],
        "metadataOnly": false,
        "routeOnly": false
      }
    },
    {
      "listen": "0.0.0.0",
      "port": 8080,
      "protocol": "shadowsocks",
      "settings": {
        "method": "2022-blake3-aes-256-gcm",
        "password": "$ss_password",
        "network": "tcp,udp",
        "ivCheck": false
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ],
        "metadataOnly": false,
        "routeOnly": false
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    }
  ]
}
EOF

# Compiling link
touch /usr/local/bin/link
cat << 'EOF' > /usr/local/bin/link
#!/bin/bash
# Сбор актуальных данных
port_vless=$(jq -r '.inbounds[0].port' /usr/local/etc/xray/config.json)
uuid=$(jq -r '.inbounds[0].settings.clients[0].id' /usr/local/etc/xray/config.json)
mode=$(jq -r '.inbounds[0].streamSettings.xhttpSettings.mode' /usr/local/etc/xray/config.json)
sni=$(jq -r '.inbounds[0].streamSettings.realitySettings.serverNames[0]' /usr/local/etc/xray/config.json)
pbk=$(cat /usr/local/etc/xray/.keys | awk -F': ' '/Password/ {print $2}')
sid=$(cat /usr/local/etc/xray/.keys | awk -F': ' '/shortsid/ {print $2}')
fp=$(jq -r '.inbounds[0].streamSettings.realitySettings.fingerprint' /usr/local/etc/xray/config.json)
ip=$(timeout 3 curl -4 -s icanhazip.com)
port_ss=$(jq -r '.inbounds[1].port' /usr/local/etc/xray/config.json)
pass=$(jq -r '.inbounds[1].settings.password' /usr/local/etc/xray/config.json)
method=$(jq -r '.inbounds[1].settings.method' /usr/local/etc/xray/config.json)
userinfo_base64=$(echo -n "$method:$pass" | base64 -w0)

# Compiling vless and shadowsocks configurations for output
vless_link="vless://$uuid@$ip:$port_vless?security=reality&path=%2F&host=&mode=$mode&sni=$sni&fp=$fp&pbk=$pbk&sid=$sid&spx=%2F&type=xhttp&encryption=none#💉 vless-xhttp"
ss_link="ss://$userinfo_base64@$ip:$port_ss#📐 shadowsocks-2022"

# Output of final data / Вывод итоговых данных
echo -e "\e[1;32mСсылки для подключения:\e[0m"
echo -e "\n\e[1;34m[+] VLESS XHTTP REALITY:\e[0m"
echo -e "\e[36m$vless_link\e[0m"

echo -e "\n\e[1;34m[+] SHADOWSOCKS 2022:\e[0m"
echo -e "\e[36m$ss_link\e[0m"

echo -e "\n\e[1;33m==================================================\e[0m"
echo "QR-код для VLESS:"
echo "$vless_link" | qrencode -t ansiutf8
echo -e "\e[1;33m==========================================================================\e[0m"
echo "QR-код для Shadowsocks:"
echo "$ss_link" | qrencode -t ansiutf8
echo -e "\e[1;33m==========================================================================\e[0m"

EOF
chmod +x /usr/local/bin/link

systemctl restart xray

# Autoupdate-check (every 6 days)
(crontab -l 2>/dev/null; echo "0 6 */6 * * bash -c \"\$(curl -L https://github.com/XTLS/Xray-install/raw/main/install-release.sh)\" @ install > /dev/null 2>&1 # Xray-update") | crontab -

shutdown -r +9

echo -e "\n\e[1;33m==================================================\e[0m"
echo -e "\e[1;32m      XRAY INSTALLATION COMPLETE 🎭\e[0m"
echo -e "\e[1;33m==================================================\e[0m"
link
